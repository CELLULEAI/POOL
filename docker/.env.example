# Cellule.ai Pool — docker-compose configuration
# Copy this file to .env and edit the values below.

# Your pool's human-readable name (shown on cellule.ai federation page)
POOL_NAME=my-community-pool

# Your public URL where cellule.ai can reach your pool.
# MUST be http(s):// reachable from the public internet.
# Examples:
#   http://203.0.113.42:8080        (IP public + port)
#   https://pool.mydomain.fr        (domain + reverse proxy TLS)
POOL_URL=http://YOUR_PUBLIC_IP:8080

# Postgres password — set a strong random string (32+ chars)
DB_PASS=CHANGE_ME_strong_random_password_here

# Admin token for /admin dashboard access (set a strong secret)
ADMIN_PASSWORD=CHANGE_ME_admin_secret
